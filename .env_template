# EverMem Plugin Configuration
# Copy this file to .env and fill in your values.

# API base URL (default: https://api.evermind.ai)
# EVERMEM_API_URL=https://api.evermind.ai

# User ID (default: claude-code-user)
# EVERMEM_USER_ID=claude-code-user

# Group ID (optional, auto-generated from project path if not set)
# EVERMEM_GROUP_ID=

# API key (required for SaaS, not needed for local EverMemOS)
# EVERMEM_API_KEY=your-api-key-here

# Proxy server port for dashboard (default: 3456)
# EVERMEM_PROXY_PORT=3456